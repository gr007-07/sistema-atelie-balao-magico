# Senha do painel em /login. Nunca envie o arquivo .env ao Git.
SENHA_OPERADOR=troque-por-uma-senha-forte

# Defina como true no Render, que fornece HTTPS.
COOKIE_SECURE=false

# Banco MySQL externo (opcional). Sem estas variáveis, a aplicação opera
# em modo de demonstração e os pedidos se perdem quando o serviço reinicia.
DB_HOST=
DB_PORT=3306
DB_NAME=ATELIE
DB_USER=
DB_PASSWORD=
